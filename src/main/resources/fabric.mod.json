  "authors": [],
  "contact": {},
  "license": "All Rights Reserved",
  "icon": "icon.png",
  "environment": "server",
  "entrypoints": {
    "main": [
      "com.authofflinebridge.Authofflinebridge"
    ]
  },
  "mixins": [
    "authofflinebridge.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "${minecraft_version}",
    "java": ">=25",
    "fabric-api": "*"
  }
}
